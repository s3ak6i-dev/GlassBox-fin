# Production environment for the backend.
# Set these as secrets in your host (Render / Railway / Fly) — do NOT commit real values.

# Neon (or any Postgres). The pooled connection string is fine; the app
# normalises the driver + SSL automatically.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Long random string — sign JWTs. Render can generate this for you.
SECRET_KEY=replace-with-a-long-random-secret

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7

# Same-origin serving (backend serves the SPA) → "*" is fine.
# Split deploy (frontend on a different host) → list the frontend origin(s).
CORS_ORIGINS=*
